algoritmo "Exercicio"
var
   L1, L2, L3: REAL
   EQ, ES: LOGICO
inicio
      Escreva ("Digite o primeiro lado:")
      Leia(L1)
      Escreva ("Digite o segundo lado:")
      Leia(L2)
      Escreva ("Digite o terceiro lado:")
      Leia(L3)
      Eq <- (L1 = L2) e (L2 = L3)
      Es <- (L1 <> L2) e (L2 <> L3)e (L1 <> L3)
      Escreval ("O Triangulo e equilatero?", Eq)
      Escreval ("O triangulo e escaleno", Es)
fimalgoritmo
