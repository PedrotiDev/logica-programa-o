algoritmo "calculo media"
var
   M, N1, N2: Real
inicio
   Escreva ("primeira nota ")
   leia (N1)
   Escreva ("segunda nota ")
   leia (N2)
   M <- (N1 + N2) / 2
   Escreval ("A media do aluno é ", M:4:2)
   se (M >= 7) entao
      Escreval ("aluno APROVADO!")
      senao
      se (M >= 5) e (M <= 7)entao
         Escreval ("aluno em RECUPERAÇAO")
      senao
         Escreval ("aluno REPROVADO!")
      fimse
   fimse
fimalgoritmo
